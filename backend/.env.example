# =====================================================
#  StudyAI — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your real values below
# =====================================================

# MongoDB Atlas (free at https://cloud.mongodb.com)
# Create cluster → Connect → Drivers → copy connection string
MONGO_URI=mongod
# JWT Secret — any long random string (keep it secret!)
JWT_SECRET=studyai_change_this_to_something_random_2026

# Groq API KEY (FREE at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Gorq Model (e.g. llama-3.1-8b-instant)
OQ_MODEL= your_groq_model_here

# Server port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
